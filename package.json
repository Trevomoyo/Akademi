{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev":        "concurrently -n server,vite -c cyan,green \"tsx --env-file=.env server.ts\" \"vite\"",
    "dev:server": "tsx --env-file=.env server.ts",
    "dev:vite":   "vite",
    "build":      "vite build && esbuild server.ts --bundle --platform=node --format=esm --outfile=server.mjs --external:dotenv",
    "start":      "node server.mjs",
    "preview":    "vite preview",
    "clean":      "rm -rf dist server.js",
    "lint":       "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@supabase/supabase-js": "^2.49.0",
    "@tiptap/core": "^2.11.5",
